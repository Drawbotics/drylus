{
  "plugins": [
    "npm",
    [
      "omit-commits",
      {
        "subject": ["[skip ci]"]
      }
    ]
  ],
  "labels": [
    {
      "name": "patch",
      "changelogTitle": "🐛 Bug fix - Patch",
      "releaseType": "patch"
    },
    {
      "name": "minor",
      "changelogTitle": "🚀 Enhancement - Minor change",
      "releaseType": "minor"
    },
    {
      "name": "major",
      "changelogTitle": "💥 Breaking - Major release",
      "releaseType": "major"
    }
  ],
  "prereleaseBranches": ["beta"]
}